# .env.example
# Gemini API Key for server-side AI interactions
GEMINI_API_KEY=

# Optional (build-time, used by the Android APK build):
# Overrides the live backend URL the packaged app calls for AI / Khatma-sync.
# If unset, it defaults to the live Cloud Run deployment hardcoded in
# src/lib/apiBase.ts. Only needed if that URL ever changes.
# VITE_API_BASE_URL=https://service-700838468324.europe-west2.run.app
