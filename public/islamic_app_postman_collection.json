        }
      ]
    },
    {
      "name": "الركن الشرعي والذكاء الاصطناعي",
      "item": [
        {
          "name": "سؤال المستشار الشرعي الذكي (Gemini Q&A)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"ما فضل صلاة الضحى ووقتها بالتفصيل؟\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/ask",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "ask"
              ]
            },
            "description": "يقوم بإرسال السؤال الديني إلى الذكاء الاصطناعي (Gemini API) ليقوم بصياغة إجابة فقهية ميسرة ومعتدلة وموثقة بالكتاب والسنة الشريفة. في حال عدم توفر مفتاح الذكاء الاصطناعي، يحتوي الباك أند على نظام ذكي مدمج (Local Fallback) يقوم بفحص الكلمات الدلالية وإرجاع إجابات حية مجهزة مسبقاً."
          },
          "response": []
        },
        {
          "name": "البحث الذكي في الأحاديث النبوية (Hadith Search)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"الرحمة وحسن الخلق للناس\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/hadith/search",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "hadith",
                "search"
              ]
            },
            "description": "يبحث بشكل شامل وذكي في أمهات كتب الحديث والسنّة الشريفة (البخاري ومسلم وغيرهما) ويرجع النتيجة كمصفوفة JSON مهيأة بـ 3 أحاديث صحيحة متعلقة بكلمة أو موضوع البحث مع الشرح والراوي والمصدر والتصنيف."
          },
          "response": []
        },
        {
          "name": "استدعاء حديث محدد بالترقيم (Hadith By Number)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"number\": 1,\n  \"book\": \"bukhari\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/hadith/by-number",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "hadith",
                "by-number"
              ]
            },
            "description": "يستدعي حديثاً شريفاً محدداً برقم ترتيبه من الكتب المعتمدة (bukhari, muslim, riyad, nawawi) مع إرجاع التشكيل والشرح الفقهي والتربوي له بالكامل عبر الذكاء الاصطناعي."
          },
          "response": []
        }
      ]
    },
